# ── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/easyrepair?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_this_to_a_long_random_secret

# ── Optional / has defaults ───────────────────────────────────────────────────
PORT=3000
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Firebase (optional — push notifications won't work without it) ────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── SMS (optional) ────────────────────────────────────────────────────────────
SMS_API_KEY=

# ── Cloudflare R2 storage (optional — file uploads won't work without it) ────
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
R2_ENDPOINT=

# ── Platform ──────────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10

# ── PostGIS (set true only if your local Postgres has PostGIS installed) ──────
USE_POSTGIS=false
